# Python
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
*.egg-info/

# Node / Wrangler
node_modules/
dist/
.wrangler/

# Wrangler config с реальными ID — public шаблон в wrangler.example.toml
cloud/worker/wrangler.toml
cloud/admin/wrangler.toml

# OS
.DS_Store
Thumbs.db

# Excel temp/lock
*.tmp
~$*

# Secrets — никогда не коммитить
.env
.env.local
.env.*.local
*.secret
secrets/
# GCP Service Account JSON (см. docs/setup.md, ключ живёт в ~/.config/finances-gsheets/key.json;
# скачанный ключ называется <gcp-project>-<hash>.json — широкий паттерн, чтобы не раскрывать имя проекта)
*-service-account*.json
finances-*.json
gcp-key*.json
service-account*.json

# Google OAuth Client JSON (см. docs/setup.md, ключ живёт в ~/.config/finances-admin/oauth-web-client.json)
client_secret*.json
*googleusercontent*.json
oauth-client*.json

# Locally generated databases (ground truth — обрабатывается отдельным backup-механизмом)
local/*.db
local/*.db-journal
local/*.db-wal
local/*.db-shm
local/backups/*.db

# Personal source data — никогда не коммитить (Legacy xlsx, CSV из Расходы ОК, скрины)
data/**
!data/README.md
!data/*/
!data/legacy/backups/.gitkeep

# Generated artefacts — пересобираются автоматически
reports/**
!reports/README.md
tools/csv/

# IDE
.vscode/
.idea/
*.swp

# Backups D1 (содержат полные финансовые данные — НИКОГДА не коммитить)
local/backups/
local/backups/d1-*.sql

# Playwright UI-тестер скриншоты (содержат реальные суммы)
local/screenshots/

# Trace / debugging
*.log
.cache/

# Personal admin .env (Web Admin локальный конфиг)
cloud/admin/.env
cloud/admin/.env.local

# Внутренние аудит-отчёты — живут локально (решение о публикации принимается отдельно)
docs/audits/2026-07-full-audit/
