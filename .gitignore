# Python
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
*.egg-info/

# Node / Wrangler
node_modules/
dist/
.wrangler/

# OS
.DS_Store
Thumbs.db

# Excel temp/lock
*.tmp
~$*

# Secrets — никогда не коммитить
.env
.env.local
.env.*.local
*.secret
secrets/

# Locally generated databases (ground truth — обрабатывается отдельным backup-механизмом)
local/*.db
local/*.db-journal
local/*.db-wal
local/*.db-shm
local/backups/*.db

# Personal source data — никогда не коммитить (Legacy xlsx, CSV из Расходы ОК, скрины)
data/**
!data/README.md
!data/*/
!data/legacy/backups/.gitkeep

# Generated artefacts — пересобираются автоматически
reports/**
!reports/README.md
tools/csv/

# IDE
.vscode/
.idea/
*.swp
local/backups/d1-*.sql
