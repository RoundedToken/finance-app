# Шаблон для .env. Скопируй в .env и заполни.

# Cloudflare Account ID — из дашборда https://dash.cloudflare.com (правая панель).
# Публичный идентификатор, не секрет.
CF_ACCOUNT_ID=your-cloudflare-account-id

# URL воркера после первого деплоя.
CF_WORKER_URL=https://finances-worker.<account>.workers.dev

# Bearer-токен для MacBook <-> Worker канала. Должен совпадать с
# `wrangler secret put SYNC_TOKEN`. Сгенерировать:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SYNC_TOKEN=generate-with-secrets-token-urlsafe-48

# Telegram bot HTTP API Token от @BotFather → /newbot.
# Если оставить пустым — wrangler secret put TELEGRAM_BOT_TOKEN надо сделать вручную.
TELEGRAM_BOT_TOKEN=123456789:ABC-DEF...

# Google Sheets с курсами валют — Publish to web → CSV link.
GOOGLE_RATES_CSV_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv
