# Скопировать в .env (или .env.local) перед `npm run dev` / `npm run build`.

# URL твоего Worker. Должен совпадать с production deployment Worker'а.
VITE_API_BASE=https://<your-worker>.workers.dev

# Опционально: dev-proxy для локальной разработки (Vite будет проксировать /v1 на этот target).
# VITE_DEV_PROXY_TARGET=https://<your-worker>.workers.dev
