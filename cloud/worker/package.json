{
  "name": "finances-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker for personal finance system: Telegram bot, REST API, D1 (источник правды), auth, cron rates",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "d1:console": "wrangler d1 execute finances-outbox --remote --command",
    "d1:apply-schema": "wrangler d1 execute finances-outbox --file=schema.sql --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/node": "^24.13.2",
    "typescript": "^5.4.0",
    "vitest": "^3.2.7",
    "wrangler": "^4.107.0"
  },
  "dependencies": {
    "zod": "^3.25.76"
  }
}
