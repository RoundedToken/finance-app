/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://telegram.org; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' __WORKER_ORIGIN__; font-src 'self' data:; base-uri 'self'; form-action 'self'; object-src 'none'

/assets/*
  Cache-Control: public, max-age=31536000, immutable
